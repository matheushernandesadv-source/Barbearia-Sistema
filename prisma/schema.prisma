generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ClientStatus {
  ativo
  inativo
}

enum AppointmentStatus {
  confirmado
  em_atendimento
  aguardando
  cancelado
  falta
}

enum PaymentMethod {
  pix
  cartao
  dinheiro
  vale
}

enum AccountStatus {
  pendente
  pago
  atrasado
}

enum SubscriptionStatus {
  ativo
  vencido
  cancelado
}

model Barber {
  id             String   @id @default(cuid())
  name           String
  role           String
  avatarInitials String
  color          String
  rating         Float    @default(5)
  active         Boolean  @default(true)
  createdAt      DateTime @default(now())

  appointments   Appointment[]
  commissions    Commission[]
  saleItems      SaleItem[]
  scheduleShifts ScheduleShift[]

  @@map("barbers")
}

model Service {
  id       String  @id @default(cuid())
  name     String
  duration Int
  price    Decimal @db.Decimal(10, 2)
  active   Boolean @default(true)

  appointments Appointment[]
  saleItems    SaleItem[]

  @@map("services")
}

model Client {
  id            String       @id @default(cuid())
  name          String
  phone         String
  birthday      String?
  preference    String?
  loyaltyPoints Int          @default(0)
  status        ClientStatus @default(ativo)
  createdAt     DateTime     @default(now())

  appointments  Appointment[]
  sales         Sale[]
  subscriptions Subscription[]
  receivables   Receivable[]

  @@map("clients")
}

model Appointment {
  id        String            @id @default(cuid())
  date      DateTime
  time      String
  clientId  String
  barberId  String
  serviceId String
  status    AppointmentStatus @default(aguardando)
  price     Decimal           @db.Decimal(10, 2)
  createdAt DateTime          @default(now())

  client  Client  @relation(fields: [clientId], references: [id])
  barber  Barber  @relation(fields: [barberId], references: [id])
  service Service @relation(fields: [serviceId], references: [id])

  @@index([date, barberId])
  @@map("appointments")
}

model WaitlistEntry {
  id              String   @id @default(cuid())
  clientName      String
  service         String
  preferredBarber String?
  desiredWindow   String
  createdAt       DateTime @default(now())

  @@map("waitlist_entries")
}

model Product {
  id       String    @id @default(cuid())
  name     String
  sku      String    @unique
  stock    Int       @default(0)
  minStock Int       @default(0)
  cost     Decimal   @db.Decimal(10, 2)
  price    Decimal   @db.Decimal(10, 2)
  expiry   DateTime?

  saleItems SaleItem[]

  @@map("products")
}

model Sale {
  id            String        @id @default(cuid())
  clientId      String?
  paymentMethod PaymentMethod
  discount      Decimal       @default(0) @db.Decimal(10, 2)
  total         Decimal       @db.Decimal(10, 2)
  createdAt     DateTime      @default(now())

  client Client?    @relation(fields: [clientId], references: [id])
  items  SaleItem[]

  @@map("sales")
}

model SaleItem {
  id        String  @id @default(cuid())
  saleId    String
  productId String?
  serviceId String?
  barberId  String?
  quantity  Int     @default(1)
  price     Decimal @db.Decimal(10, 2)

  sale    Sale     @relation(fields: [saleId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id])
  service Service? @relation(fields: [serviceId], references: [id])
  barber  Barber?  @relation(fields: [barberId], references: [id])

  @@map("sale_items")
}

model Commission {
  id       String  @id @default(cuid())
  barberId String
  refMonth String
  service  Decimal @default(0) @db.Decimal(10, 2)
  product  Decimal @default(0) @db.Decimal(10, 2)
  bonus    Decimal @default(0) @db.Decimal(10, 2)
  total    Decimal @default(0) @db.Decimal(10, 2)
  paid     Boolean @default(false)

  barber Barber @relation(fields: [barberId], references: [id])

  @@unique([barberId, refMonth])
  @@map("commissions")
}

model Receivable {
  id          String        @id @default(cuid())
  description String
  clientId    String?
  dueDate     DateTime
  value       Decimal       @db.Decimal(10, 2)
  status      AccountStatus @default(pendente)

  client Client? @relation(fields: [clientId], references: [id])

  @@map("receivables")
}

model Payable {
  id          String        @id @default(cuid())
  description String
  dueDate     DateTime
  value       Decimal       @db.Decimal(10, 2)
  status      AccountStatus @default(pendente)

  @@map("payables")
}

model Plan {
  id       String  @id @default(cuid())
  name     String
  price    Decimal @db.Decimal(10, 2)
  benefits String

  subscriptions Subscription[]

  @@map("plans")
}

model Subscription {
  id          String             @id @default(cuid())
  clientId    String
  planId      String
  startedAt   DateTime           @default(now())
  nextBilling DateTime
  status      SubscriptionStatus @default(ativo)

  client Client @relation(fields: [clientId], references: [id])
  plan   Plan   @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

model ScheduleShift {
  id       String @id @default(cuid())
  barberId String
  weekday  Int
  shift    String

  barber Barber @relation(fields: [barberId], references: [id])

  @@unique([barberId, weekday])
  @@map("schedule_shifts")
}
